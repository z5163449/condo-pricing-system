// Prisma schema for Condo Pricing System
// Database: SQLite (development), can swap to PostgreSQL for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Project ──────────────────────────────────────────────────────────────────
model Project {
  id                 String              @id @default(cuid())
  nameEn             String
  nameZh             String
  description        String?
  totalUnitsExpected Int?
  roundingUnit       Int                 @default(100)
  status             String              @default("draft") // draft | in-review | approved
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  blocks             Block[]
  ranks              Rank[]
  pricingParameters  PricingParameters?
  sessions           Session[]
  scenarios          PricingScenario[]
}

// ─── Block ────────────────────────────────────────────────────────────────────
model Block {
  id              String   @id @default(cuid())
  projectId       String
  blockName       String
  totalStoreys    Int
  startingFloor   Int      @default(1)
  excludedFloors  String   @default("[]") // JSON array: e.g. "[4, 13, 14]"

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stacks          Stack[]
}

// ─── Stack ────────────────────────────────────────────────────────────────────
model Stack {
  id               String   @id @default(cuid())
  blockId          String
  stackNumber      Int
  unitTypeCode     String   // e.g. "A1", "B2"
  bedroomType      String   // 2BR | 3BR | 4BR | 5BR
  standardSizeSqft Float
  facing           String?  // e.g. "North", "Pool View"
  notes            String?
  rankId           String?
  hasPenthouse         Boolean  @default(false)
  penthouseUse         String?  // e.g. "Rooftop Garden", "Sky Terrace"
  penthouseSizeSqft    Float?   // size of penthouse unit (sqft), shown when hasPenthouse = true
  stackStartingFloor   Int?     // overrides block startingFloor for this stack if set
  stackExcludedFloors  String?  // JSON array of additional excluded floors (union with block excludedFloors)
  stackStartingPSF     Float?   // locked starting PSF for lowest valid floor of this stack
  stackStartingPSFLocked Boolean @default(false)
  stackIncrements      String?  // JSON array of increment bands — overrides rank bands for this stack
  stackIncrementsLocked Boolean  @default(false)

  block             Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  rank             Rank?    @relation(fields: [rankId], references: [id])
  units            Unit[]
}

// ─── Rank ─────────────────────────────────────────────────────────────────────
model Rank {
  id               String           @id @default(cuid())
  projectId        String
  rankNumber       Int
  labelEn          String
  labelZh          String
  rankDifferential Float?

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stacks           Stack[]
  floorIncrements  FloorIncrement[]
}

// ─── FloorIncrement ───────────────────────────────────────────────────────────
model FloorIncrement {
  id           String @id @default(cuid())
  rankId       String
  fromFloor    Int
  toFloor      Int
  incrementPSF Float?

  rank         Rank   @relation(fields: [rankId], references: [id], onDelete: Cascade)
}

// ─── Unit ─────────────────────────────────────────────────────────────────────
model Unit {
  id                  String  @id @default(cuid())
  stackId             String
  unitNumber          String  // e.g. "#05-01"
  floor               Int
  sizeSqft            Float
  isPenthouse         Boolean @default(false)

  // Calculated values (populated by pricing engine)
  calculatedPSF       Float?
  calculatedPrice     Float?

  // Manual overrides
  manualOverridePSF   Float?
  manualOverridePrice Float?
  isManualOverride    Boolean @default(false)

  // Final values (override if set, else calculated)
  finalPSF            Float?
  finalPrice          Float?

  // Cumulative adjustment factor since last generation (1.0 = no adjustment)
  cumulativeAdjustment Float  @default(1.0)

  stack               Stack   @relation(fields: [stackId], references: [id], onDelete: Cascade)
}

// ─── PricingParameters ────────────────────────────────────────────────────────
model PricingParameters {
  id                    String  @id @default(cuid())
  projectId             String  @unique
  targetOverallAvgPSF   Float?
  targetBedroomPSF      String  @default("{}") // JSON: {"Studio": 1500, "2BR": 1800, "Dual-Key": 2200}
  defaultFloorIncrement Float   @default(10)
  penthouseMultiplier   Float   @default(1.0)
  luckyFloorPremiums    String  @default("{}") // JSON: e.g. {"8": 0.02, "18": 0.03}
  roundingUnit          Int     @default(100)
  typeCodeHierarchy     String? // JSON array of type codes ordered highest PSF to lowest, e.g. ["B2","B2a","C1"]
  rankReference         String? // rankId of the reference rank (differential = 0) used for relative pricing

  project               Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── PricingScenario ──────────────────────────────────────────────────────────
model PricingScenario {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  notes     String?
  isLocked  Boolean  @default(false)
  isBase    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots UnitSnapshot[]
}

// ─── UnitSnapshot ─────────────────────────────────────────────────────────────
model UnitSnapshot {
  id               String          @id @default(cuid())
  scenarioId       String
  scenario         PricingScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  unitId           String          // reference to Unit.id at snapshot time (may become stale after regeneration)
  floor            Int
  stackId          String
  unitNumber       String
  sizeSqft         Float
  finalPSF         Float
  finalPrice       Float
  isManualOverride Boolean
}

// ─── Session (snapshot) ───────────────────────────────────────────────────────
model Session {
  id           String   @id @default(cuid())
  projectId    String
  label        String
  snapshotJSON String   // Full JSON snapshot of pricing at a point in time
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
